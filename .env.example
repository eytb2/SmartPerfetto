# SmartPerfetto root env example (Docker Hub)
# Copy to .env for docker-compose.hub.yml:
#   cp .env.example .env
#
# Local source users usually want backend/.env instead:
#   cp backend/.env.example backend/.env
#
# If local `claude` already works in the same terminal, no AI env is needed for
# source runs. Docker cannot see host Claude Code auth, so Docker needs one
# explicit provider block below. Keep unused credential lines commented.

# ---------------------------------------------------
# Server
# ---------------------------------------------------
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:10000

# API Authentication (recommended in any shared environment)
# SMARTPERFETTO_API_KEY=replace_with_a_strong_random_secret
# Enterprise mode disables unauthenticated dev fallback. SSO trusted headers are
# only safe behind an OIDC-authenticated reverse proxy that strips inbound
# client-supplied SSO headers.
# SMARTPERFETTO_ENTERPRISE=false
# SMARTPERFETTO_SSO_TRUSTED_HEADERS=false
# SMARTPERFETTO_SSO_COOKIE_SECRET=replace_with_a_32_byte_random_secret
# SMARTPERFETTO_OIDC_ISSUER_URL=https://idp.example.com
# SMARTPERFETTO_OIDC_CLIENT_ID=smartperfetto
# SMARTPERFETTO_OIDC_CLIENT_SECRET=replace_with_oidc_client_secret
# SMARTPERFETTO_OIDC_REDIRECT_URI=http://localhost:3000/api/auth/oidc/callback
# SMARTPERFETTO_OIDC_EMAIL_DOMAIN_MAP=example.com=default-dev-tenant

# ---------------------------------------------------
# AI runtime
# ---------------------------------------------------
# Default runtime is claude-agent-sdk when no provider/env override is set.
# Valid values: claude-agent-sdk, openai-agents-sdk.
# If both ANTHROPIC_* and OPENAI_* are present, SMARTPERFETTO_AGENT_RUNTIME
# selects the active side. Without it, SmartPerfetto still defaults to Claude.

# Option 1: Anthropic direct
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_LIGHT_MODEL=claude-haiku-4-5

# Option 2: OpenAI direct
# SMARTPERFETTO_AGENT_RUNTIME=openai-agents-sdk
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_AGENTS_PROTOCOL=responses
# OPENAI_MODEL=gpt-5.5
# OPENAI_LIGHT_MODEL=gpt-5.4-mini

# Option 3: Claude Code-compatible third-party provider
# Uncomment ONE provider block. Treat prefilled Base URLs as starting points;
# usually you only replace the key, but provider-console URLs take precedence.
# SmartPerfetto uses CLAUDE_MODEL / CLAUDE_LIGHT_MODEL, not ANTHROPIC_MODEL.
# Prefilled Base URLs below are based on public provider information and may be
# incomplete, stale, account-specific, or region-specific. If analysis fails at
# connection/tool-call time, verify both the Base URL and model IDs in your
# provider console first. Please open an issue or PR when a public preset needs
# to be corrected.

# DeepSeek
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_deepseek_api_key_here
# CLAUDE_MODEL=deepseek-v4-pro
# CLAUDE_LIGHT_MODEL=deepseek-v4-flash
#
# DeepSeek OpenAI-compatible alternative:
# SMARTPERFETTO_AGENT_RUNTIME=openai-agents-sdk
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=your_deepseek_api_key_here
# OPENAI_AGENTS_PROTOCOL=chat_completions
# OPENAI_MODEL=deepseek-v4-pro
# OPENAI_LIGHT_MODEL=deepseek-v4-flash

# GLM / Z.ai
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# ANTHROPIC_API_KEY=your_zhipuai_api_key_here
# CLAUDE_MODEL=glm-5.1
# CLAUDE_LIGHT_MODEL=glm-4.5-air
#
# GLM OpenAI-compatible alternative:
# SMARTPERFETTO_AGENT_RUNTIME=openai-agents-sdk
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OPENAI_API_KEY=your_zhipuai_api_key_here
# OPENAI_AGENTS_PROTOCOL=chat_completions
# OPENAI_MODEL=glm-5.1
# OPENAI_LIGHT_MODEL=glm-4.5-air

