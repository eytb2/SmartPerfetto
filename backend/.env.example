# Server Configuration
PORT=3000
NODE_ENV=development

# API Authentication (recommended in any shared environment)
# If set, all protected APIs require:
#   Authorization: Bearer <SMARTPERFETTO_API_KEY>
# or x-api-key header.
# SMARTPERFETTO_API_KEY=replace_with_a_strong_random_secret

# Optional request throttling (in-memory, per API key/IP)
# SMARTPERFETTO_USAGE_MAX_REQUESTS=200
# SMARTPERFETTO_USAGE_MAX_TRACE_REQUESTS=100
# SMARTPERFETTO_USAGE_WINDOW_MS=86400000

# AI Service Configuration
# Default: claude-code (Claude Agent SDK). Fallback: deepseek (legacy agentv2, deprecated).
# AI_SERVICE=claude-code

# OpenAI Configuration
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com

# Anthropic Configuration (API-based)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Claude Code Agent SDK Configuration (default, uses Claude Max subscription, no API key needed)
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MAX_TURNS=15
# CLAUDE_MAX_BUDGET_USD=5
# CLAUDE_EFFORT=high

# DeepSeek Configuration (recommended)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# OpenAI-compatible DeepSeek endpoint also supports: https://api.deepseek.com/v1
# Note: /v1 here is API path compatibility only, not model version.
DEEPSEEK_MODEL=deepseek-chat
# deepseek-chat = DeepSeek-V3.2 non-thinking mode (128K context)
# deepseek-reasoner = DeepSeek-V3.2 thinking mode (128K context)
# Optional dedicated reasoning model for fallback after provider/model failures
# DEEPSEEK_REASONING_MODEL=deepseek-reasoner
# Router order (default): glm-5 -> deepseek-reasoner -> deepseek-chat
# Optional override:
# MODEL_DEFAULT=glm-5
# MODEL_FALLBACK_CHAIN=deepseek-reasoner,deepseek-chat
# Native OpenAI-compatible invocation defaults (enabled by default)
# MODEL_NATIVE_OPTIONS_ENABLED=true
# MODEL_NATIVE_TOOLS=[{"type":"function","function":{"name":"inspect_trace","description":"Inspect trace signals","parameters":{"type":"object","properties":{"focus":{"type":"string"}}}}}]
# MODEL_NATIVE_TOOL_CHOICE=auto
# MODEL_NATIVE_REASONING={"effort":"medium"}
# Optional per-task reasoning override (JSON object)
# MODEL_NATIVE_REASONING_BY_TASK={"planning":{"effort":"high"},"evaluation":{"effort":"high"},"formatting":{"effort":"low"}}

# GLM (Zhipu AI) — removed: non-functional provider

# LLM Adapter reliability controls (legacy expert path)
# LLM_REQUEST_TIMEOUT_MS=45000
# LLM_MAX_RETRIES=2
# LLM_RETRY_BASE_DELAY_MS=600
# LLM_MAX_RETRY_DELAY_MS=5000

# Agent task safety limits
# AGENT_SQL_MAX_ROWS=1000
# AGENT_SQL_TABLE_CACHE_TTL_MS=300000
# AGENT_TASK_TIMEOUT_MS=180000

# File Upload
MAX_FILE_SIZE=2147483648
UPLOAD_DIR=./uploads

# Perfetto Configuration (optional - uses default paths if not set)
# TRACE_PROCESSOR_PATH=/path/to/trace_processor_shell
# PERFETTO_PATH=/path/to/perfetto

# CORS
FRONTEND_URL=http://localhost:10000
